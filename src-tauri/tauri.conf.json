{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "BestText",
  "version": "0.1.0",
  "identifier": "com.besttext.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run build && python3 -m http.server 4173 -d dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BestText",
        "width": 520,
        "height": 640,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "resources": ["icons/tray-icon.png"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
