{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "WhisloAI",
  "version": "0.1.15",
  "identifier": "com.whisloai.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:4173",
    "beforeDevCommand": "npm run build && python3 -m http.server 4173 -d dist",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "WhisloAI",
        "width": 520,
        "height": 640,
        "visible": false,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "macOS": {
      "infoPlist": "Info.plist",
      "entitlements": "Entitlements.plist"
    },
    "resources": {
      "../src/trayicon.png": "icons/tray-icon.png"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Canopix/WhisloAI/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEI4RUY0Nzk3M0M3OUQwRApSV1FObmNkemVmU09DNm1vU0ZmQm5BNUFrSnpvaktsMm96WGloWXZBSUZHTnVXSkRVb1RCdGRUZQo="
    }
  }
}
