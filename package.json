{
  "name": "whisloai",
  "version": "0.1.23",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "description": "Minimal desktop writing helper built with Tauri",
  "scripts": {
    "build": "rm -rf dist && mkdir -p dist && cp -R src/* dist/",
    "clean": "rm -rf dist out .next",
    "rebuild": "npm run clean && npm run build && npm run tauri build",
    "dev": "tauri dev",
    "run:prod": "bash ./scripts/build-install-local-macos.sh",
    "install:local": "bash ./scripts/install-local-macos.sh",
    "build:local": "bash ./scripts/build-install-local-macos.sh",
    "reset:local:blank": "bash ./scripts/reset-local-blank-state-macos.sh",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.27",
    "lucide": "^0.577.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
